# Lapaas OS Production Environment Configuration
# IMPORTANT: Copy this file to .env.production and update all values

# Server Configuration
NODE_ENV=production
PORT=3000

# JWT Configuration (CRITICAL: Change these in production!)
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_64_BYTE_HEX_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database Configuration
DATABASE_PATH=./lapaas.db
DATABASE_ENCRYPTION_KEY=CHANGE_THIS_TO_A_SECURE_32_BYTE_HEX_STRING

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://app.lapaas.com,https://lapaas.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Email Configuration (for password reset, invitations)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@lapaas.com

# Security Settings
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_THIS_TO_A_SECURE_SECRET
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
SECURITY_LOG_PATH=./logs/security.log

# Feature Flags
ENABLE_2FA=false
ENABLE_API_KEYS=false
ENABLE_AUDIT_LOG=true

# Admin Configuration
# IMPORTANT: Change default admin credentials immediately after first login
DEFAULT_ADMIN_EMAIL=admin@your-domain.com
# Do NOT set default password in production - force password reset on first login
